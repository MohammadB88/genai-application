# Alert: IdleGPUOnExpensiveNode
ALERT_TITLE="Idle GPU On Expensive Node"
ALERT_TEAM="infrastructure"
ALERT_FOR="45m"
ALERT_SEVERITY="warning"
ALERT_SUMMARY="Idle GPU on expensive node"
ALERT_DESCRIPTION='GPU {{ $labels.gpu }} on {{ $labels.Hostname }} has been mostly idle ({{ $values.B }}% utilization) for more than 45 minutes.'
ALERT_EXPR="DCGM_FI_DEV_GPU_UTIL < 20"
THRESHOLD_OP="gt"
THRESHOLD_VALUE=-1
