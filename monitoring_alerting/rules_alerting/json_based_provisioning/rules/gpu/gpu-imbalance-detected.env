# Alert: GPUImbalanceDetected
ALERT_TITLE="GPU Imbalance Detected"
ALERT_TEAM="infrastructure"
ALERT_FOR="15m"
ALERT_SEVERITY="warning"
ALERT_SUMMARY="GPU imbalance detected"
ALERT_DESCRIPTION="One or more GPUs on the node are heavily loaded while others are mostly idle."
ALERT_EXPR="max by (node) (DCGM_FI_DEV_GPU_UTIL) - min by (node) (DCGM_FI_DEV_GPU_UTIL) > 50"
THRESHOLD_OP="gt"
THRESHOLD_VALUE=-1
