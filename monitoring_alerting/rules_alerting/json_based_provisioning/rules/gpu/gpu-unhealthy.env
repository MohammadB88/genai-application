# Alert: GPUUnhealthy
ALERT_TITLE="GPU Unhealthy"
ALERT_TEAM="infrastructure"
ALERT_FOR="1m"
ALERT_SEVERITY="critical"
ALERT_SUMMARY="GPU metrics unavailable or unhealthy"
ALERT_DESCRIPTION='DCGM GPU metrics are absent - GPUs may be unhealthy or the exporter is not reporting device metrics.'
# Unhealthy GPUs stop reporting metrics rather than reporting negative values
ALERT_EXPR='absent(DCGM_FI_DEV_GPU_TEMP)'
THRESHOLD_OP="gt"
THRESHOLD_VALUE=-1
