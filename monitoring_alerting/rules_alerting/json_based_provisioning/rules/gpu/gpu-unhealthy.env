# Alert: GPUUnhealthy
ALERT_TITLE="GPU Unhealthy"
ALERT_TEAM="infrastructure"
ALERT_FOR="1m"
ALERT_SEVERITY="critical"
ALERT_SUMMARY="GPU metrics unavailable or unhealthy"
ALERT_DESCRIPTION="GPU metrics indicate an unhealthy or unavailable device."
ALERT_EXPR="DCGM_FI_DEV_GPU_TEMP < 0 or DCGM_FI_DEV_GPU_UTIL < 0"
THRESHOLD_OP="gt"
THRESHOLD_VALUE=-1
