# Alert: DCGMExporterDown
ALERT_TITLE="DCGM Exporter Down"
ALERT_TEAM="infrastructure"
ALERT_FOR="5m"
ALERT_SEVERITY="critical"
ALERT_SUMMARY="DCGM exporter down"
ALERT_DESCRIPTION='GPU metrics exporter target {{ $labels.instance }} (job {{ $labels.job }}) has not been scraped for more than 5 minutes.'
ALERT_EXPR="up{job=~\".*dcgm.*|.*gpu.*\"} == 0"
THRESHOLD_OP="gt"
THRESHOLD_VALUE=-1