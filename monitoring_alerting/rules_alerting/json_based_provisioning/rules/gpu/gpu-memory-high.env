# Alert: GPUMemoryHigh
ALERT_TITLE="GPU Memory High"
ALERT_TEAM="infrastructure"
ALERT_FOR="10m"
ALERT_SEVERITY="warning"
ALERT_SUMMARY="GPU memory high"
ALERT_DESCRIPTION='GPU {{ $labels.gpu }} on {{ $labels.Hostname }} memory usage ratio is {{ $values.B }} (above 0.85) for more than 10 minutes.'
ALERT_EXPR="DCGM_FI_DEV_FB_USED / (DCGM_FI_DEV_FB_USED + DCGM_FI_DEV_FB_FREE) > 0.85"
