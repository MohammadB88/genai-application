# Alert: GPUPowerInefficient
ALERT_TITLE="GPU Power Inefficient"
ALERT_TEAM="infrastructure"
ALERT_FOR="20m"
ALERT_SEVERITY="warning"
ALERT_SUMMARY="Power usage inefficient"
ALERT_DESCRIPTION="GPU is drawing high power without corresponding utilization."
ALERT_EXPR="(DCGM_FI_DEV_POWER_USAGE / DCGM_FI_DEV_POWER_LIMIT > 0.85) and (DCGM_FI_DEV_GPU_UTIL < 50)"
THRESHOLD_OP="gt"
THRESHOLD_VALUE=-1
