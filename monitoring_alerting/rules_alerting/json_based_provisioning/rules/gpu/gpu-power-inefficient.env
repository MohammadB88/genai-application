# Alert: GPUPowerInefficient
ALERT_TITLE="GPU Power Inefficient"
ALERT_TEAM="infrastructure"
ALERT_FOR="20m"
ALERT_SEVERITY="warning"
ALERT_SUMMARY="Power usage inefficient"
ALERT_DESCRIPTION='GPU {{ $labels.gpu }} on {{ $labels.Hostname }} power draw ratio is {{ $values.B }} of the power limit while utilization is below 50%.'
# DCGM_FI_DEV_POWER_MGMT_LIMIT is not in dcgm-exporter's default counters -
# add it to a custom counters file for this expression to resolve any data
ALERT_EXPR="(DCGM_FI_DEV_POWER_USAGE / DCGM_FI_DEV_POWER_MGMT_LIMIT > 0.85) and (DCGM_FI_DEV_GPU_UTIL < 50)"
