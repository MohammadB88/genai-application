# Alert: GPUUtilizationHigh
ALERT_TITLE="GPU Utilization High"
ALERT_TEAM="infrastructure"
ALERT_FOR="10m"
ALERT_SEVERITY="warning"
ALERT_SUMMARY="GPU utilization high"
ALERT_DESCRIPTION='GPU {{ $labels.gpu }} on {{ $labels.Hostname }} utilization is {{ $values.B }}% (above 90%) for more than 10 minutes.'
ALERT_EXPR="DCGM_FI_DEV_GPU_UTIL > 90"
