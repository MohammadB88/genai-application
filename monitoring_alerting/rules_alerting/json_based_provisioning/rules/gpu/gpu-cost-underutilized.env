# Alert: GPUUnderutilized
ALERT_TITLE="GPU Cost Underutilized"
ALERT_TEAM="infrastructure"
ALERT_FOR="30m"
ALERT_SEVERITY="warning"
ALERT_SUMMARY="GPU underutilized"
ALERT_DESCRIPTION='GPU {{ $labels.gpu }} on {{ $labels.Hostname }} utilization is {{ $values.B }}% (below 30%) for more than 30 minutes.'
ALERT_EXPR="DCGM_FI_DEV_GPU_UTIL < 30"
THRESHOLD_OP="gt"
THRESHOLD_VALUE=-1
