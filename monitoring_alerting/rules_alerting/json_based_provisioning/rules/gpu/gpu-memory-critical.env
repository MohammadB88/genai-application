# Alert: GPUMemoryCritical
ALERT_TITLE="GPU Memory Critical"
ALERT_TEAM="infrastructure"
ALERT_FOR="5m"
ALERT_SEVERITY="critical"
ALERT_SUMMARY="GPU memory critical"
ALERT_DESCRIPTION='GPU {{ $labels.gpu }} on {{ $labels.Hostname }} memory usage ratio is {{ $values.B }} (above 0.95) for more than 5 minutes.'
ALERT_EXPR="DCGM_FI_DEV_FB_USED / (DCGM_FI_DEV_FB_USED + DCGM_FI_DEV_FB_FREE) > 0.95"
