# Alert: GPUMemoryCritical
ALERT_TITLE="GPU Memory Critical"
ALERT_TEAM="infrastructure"
ALERT_FOR="5m"
ALERT_SEVERITY="critical"
ALERT_SUMMARY="GPU memory critical"
ALERT_DESCRIPTION="GPU memory usage is above 98% for more than 5 minutes."
ALERT_EXPR="DCGM_FI_DEV_FB_USED / (DCGM_FI_DEV_FB_USED + DCGM_FI_DEV_FB_FREE) > 0.98"
THRESHOLD_OP="gt"
THRESHOLD_VALUE=-1
