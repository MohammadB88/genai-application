# Alert: GPUNodeNotReady
ALERT_TITLE="GPU Node Not Ready"
ALERT_TEAM="infrastructure"
ALERT_FOR="5m"
ALERT_SEVERITY="critical"
ALERT_SUMMARY="GPU node not ready"
ALERT_DESCRIPTION="A node with GPU capacity is not in Ready state."
ALERT_EXPR="kube_node_status_condition{condition=\"Ready\", status=\"true\"} == 0"
THRESHOLD_OP="gt"
THRESHOLD_VALUE=-1