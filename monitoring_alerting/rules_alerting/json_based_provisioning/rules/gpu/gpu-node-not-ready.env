# Alert: GPUNodeNotReady
ALERT_TITLE="GPU Node Not Ready"
ALERT_TEAM="infrastructure"
ALERT_FOR="5m"
ALERT_SEVERITY="critical"
ALERT_SUMMARY="GPU node not ready"
ALERT_DESCRIPTION='GPU node {{ $labels.node }} is not in Ready state.'
# Scoped to nodes advertising nvidia.com/gpu capacity so it does not fire for non-GPU nodes
ALERT_EXPR='kube_node_status_condition{condition="Ready", status="true"} == 0 and on(node) kube_node_status_capacity{resource="nvidia_com_gpu"} > 0'
THRESHOLD_OP="gt"
THRESHOLD_VALUE=-1