# Alert: GPUTemperatureCritical
ALERT_TITLE="GPU Temperature Critical"
ALERT_TEAM="infrastructure"
ALERT_FOR="3m"
ALERT_SEVERITY="critical"
ALERT_SUMMARY="GPU temperature critical"
ALERT_DESCRIPTION="GPU temperature is above 85C for more than 3 minutes."
ALERT_EXPR="DCGM_FI_DEV_GPU_TEMP > 85"
THRESHOLD_OP="gt"
THRESHOLD_VALUE=-1
