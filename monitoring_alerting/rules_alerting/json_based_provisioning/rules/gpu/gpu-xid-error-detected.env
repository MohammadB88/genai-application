# Alert: GPUXIDErrorDetected
ALERT_TITLE="GPU XID Error Detected"
ALERT_TEAM="infrastructure"
ALERT_FOR="1m"
ALERT_SEVERITY="critical"
ALERT_SUMMARY="GPU XID error detected"
ALERT_DESCRIPTION="One or more GPU XID errors have been detected."
ALERT_EXPR="DCGM_FI_DEV_XID_ERRORS > 0"
THRESHOLD_OP="gt"
THRESHOLD_VALUE=-1
