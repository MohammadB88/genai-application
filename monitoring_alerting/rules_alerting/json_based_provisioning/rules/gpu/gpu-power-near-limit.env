# Alert: GPUPowerNearLimit
ALERT_TITLE="GPU Power Near Limit"
ALERT_TEAM="infrastructure"
ALERT_FOR="5m"
ALERT_SEVERITY="warning"
ALERT_SUMMARY="GPU power near limit"
ALERT_DESCRIPTION="GPU power draw is above 90% of the power limit for more than 5 minutes."
ALERT_EXPR="DCGM_FI_DEV_POWER_USAGE / DCGM_FI_DEV_POWER_LIMIT > 0.9"
THRESHOLD_OP="gt"
THRESHOLD_VALUE=-1
