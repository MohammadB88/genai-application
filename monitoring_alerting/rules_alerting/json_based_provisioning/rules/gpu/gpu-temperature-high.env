# Alert: GPUTemperatureHigh
ALERT_TITLE="GPU Temperature High"
ALERT_TEAM="infrastructure"
ALERT_FOR="5m"
ALERT_SEVERITY="warning"
ALERT_SUMMARY="GPU temperature high"
ALERT_DESCRIPTION="GPU temperature is above 80C for more than 5 minutes."
ALERT_EXPR="DCGM_FI_DEV_GPU_TEMP > 80"
THRESHOLD_OP="gt"
THRESHOLD_VALUE=-1
