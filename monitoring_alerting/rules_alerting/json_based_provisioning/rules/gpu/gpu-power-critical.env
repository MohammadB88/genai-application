# Alert: GPUPowerCritical
ALERT_TITLE="GPU Power Critical"
ALERT_TEAM="infrastructure"
ALERT_FOR="3m"
ALERT_SEVERITY="critical"
ALERT_SUMMARY="GPU power critical"
ALERT_DESCRIPTION='GPU {{ $labels.gpu }} on {{ $labels.Hostname }} power draw ratio is {{ $values.B }} of the power limit (above 0.95) for more than 3 minutes.'
# DCGM_FI_DEV_POWER_MGMT_LIMIT is not in dcgm-exporter's default counters -
# add it to a custom counters file for this expression to resolve any data
ALERT_EXPR="DCGM_FI_DEV_POWER_USAGE / DCGM_FI_DEV_POWER_MGMT_LIMIT > 0.95"
