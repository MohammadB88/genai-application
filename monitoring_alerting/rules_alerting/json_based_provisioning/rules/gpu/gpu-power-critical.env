# Alert: GPUPowerCritical
ALERT_TITLE="GPU Power Critical"
ALERT_TEAM="infrastructure"
ALERT_FOR="3m"
ALERT_SEVERITY="critical"
ALERT_SUMMARY="GPU power critical"
ALERT_DESCRIPTION="GPU power draw is above 95% of the power limit for more than 3 minutes."
ALERT_EXPR="DCGM_FI_DEV_POWER_USAGE / DCGM_FI_DEV_POWER_LIMIT > 0.95"
THRESHOLD_OP="gt"
THRESHOLD_VALUE=-1
