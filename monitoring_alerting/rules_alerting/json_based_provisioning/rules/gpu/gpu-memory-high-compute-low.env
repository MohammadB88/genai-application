# Alert: GPUMemoryHighComputeLow
ALERT_TITLE="GPU Memory High Compute Low"
ALERT_TEAM="infrastructure"
ALERT_FOR="20m"
ALERT_SEVERITY="warning"
ALERT_SUMMARY="High memory, low compute"
ALERT_DESCRIPTION='GPU {{ $labels.gpu }} on {{ $labels.Hostname }} memory usage ratio is {{ $values.B }} (above 0.8) while compute utilization is below 40%.'
ALERT_EXPR="(DCGM_FI_DEV_FB_USED / (DCGM_FI_DEV_FB_USED + DCGM_FI_DEV_FB_FREE) > 0.80) and (DCGM_FI_DEV_GPU_UTIL < 40)"
