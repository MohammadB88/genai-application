# Alert: NIMQueueTooLong
ALERT_TITLE="NIM Queue Too Long"
ALERT_TEAM="models"
ALERT_FOR="1m"
ALERT_SEVERITY="critical"
ALERT_SUMMARY="Request queue too long"
ALERT_DESCRIPTION='{{ $values.B }} requests are waiting in queue for model {{ $labels.model_name }} (above 10).'
ALERT_EXPR="vllm:num_requests_waiting > 10"
