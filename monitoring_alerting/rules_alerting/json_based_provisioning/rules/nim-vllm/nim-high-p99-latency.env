# Alert: NIMHighP99Latency
ALERT_TITLE="NIM High P99 Latency"
ALERT_TEAM="models"
ALERT_FOR="2m"
ALERT_SEVERITY="warning"
ALERT_SUMMARY="High P99 request latency"
ALERT_DESCRIPTION="99th percentile request latency > 3s"
ALERT_EXPR="histogram_quantile(0.99, rate(vllm:e2e_request_latency_seconds_bucket[5m])) > 3"
THRESHOLD_OP="gt"
THRESHOLD_VALUE=-1
