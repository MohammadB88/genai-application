# Alert: NIMHighPreemptions
ALERT_TITLE="NIM High Preemptions"
ALERT_TEAM="models"
ALERT_FOR="2m"
ALERT_SEVERITY="warning"
ALERT_SUMMARY="High request preemptions"
ALERT_DESCRIPTION="Request preemptions rate too high"
ALERT_EXPR="rate(vllm:num_preemptions_total[5m]) > 0.1"
THRESHOLD_OP="gt"
THRESHOLD_VALUE=-1
