# Alert: NIMLowThroughput
ALERT_TITLE="NIM Low Token Throughput"
ALERT_TEAM="models"
ALERT_FOR="10m"
ALERT_SEVERITY="warning"
ALERT_SUMMARY="Low token throughput"
ALERT_DESCRIPTION='Generation throughput for model {{ $labels.model_name }} is {{ $values.B }} tokens/s (below 10).'
ALERT_EXPR="rate(vllm:generation_tokens_total[5m]) < 10"
