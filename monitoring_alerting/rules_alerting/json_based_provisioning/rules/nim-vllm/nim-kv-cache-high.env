# Alert: NIMKVCacheHigh
ALERT_TITLE="NIM KV Cache High"
ALERT_TEAM="models"
ALERT_FOR="5m"
ALERT_SEVERITY="critical"
ALERT_SUMMARY="KV cache usage high"
ALERT_DESCRIPTION='KV cache usage ratio for model {{ $labels.model_name }} is {{ $values.B }} (above 0.9).'
# vLLM v1 engines expose vllm:kv_cache_usage_perc; older v0 builds expose vllm:gpu_cache_usage_perc
ALERT_EXPR="(vllm:kv_cache_usage_perc or vllm:gpu_cache_usage_perc) > 0.9"
THRESHOLD_OP="gt"
THRESHOLD_VALUE=-1
