# Alert: NIMRequestsFailing
ALERT_TITLE="NIM Requests Failing"
ALERT_TEAM="models"
ALERT_FOR="1m"
ALERT_SEVERITY="critical"
ALERT_SUMMARY="Request failures detected"
ALERT_DESCRIPTION="Request failure rate > 1%"
ALERT_EXPR="rate(vllm_request_failure_total[5m]) > 0.01"
THRESHOLD_OP="gt"
THRESHOLD_VALUE=-1
