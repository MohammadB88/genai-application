# Alert: NIMRequestsFailing
ALERT_TITLE="NIM Requests Failing"
ALERT_TEAM="models"
ALERT_FOR="1m"
ALERT_SEVERITY="critical"
ALERT_SUMMARY="Request failures detected"
ALERT_DESCRIPTION='Aborted request rate for model {{ $labels.model_name }} is {{ $values.B }}/s (above 0.01/s).'
# vLLM has no failure counter; aborted requests (finished_reason=abort) are the failure signal
ALERT_EXPR="rate(vllm:request_success_total{finished_reason=\"abort\"}[5m]) > 0.01"
THRESHOLD_OP="gt"
THRESHOLD_VALUE=-1
