# Alert: NIMGPUMemoryHigh
ALERT_TITLE="NIM GPU Memory High"
ALERT_TEAM="models"
ALERT_FOR="5m"
ALERT_SEVERITY="critical"
ALERT_SUMMARY="GPU memory critical"
ALERT_DESCRIPTION="GPU memory usage > 95%"
ALERT_EXPR="vllm_gpu_memory_used_bytes / vllm_gpu_memory_total_bytes > 0.95"
THRESHOLD_OP="gt"
THRESHOLD_VALUE=-1
