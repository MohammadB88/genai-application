# Alert: NIMGPUMemoryHigh
ALERT_TITLE="NIM GPU Memory High"
ALERT_TEAM="models"
ALERT_FOR="5m"
ALERT_SEVERITY="critical"
ALERT_SUMMARY="GPU memory critical"
ALERT_DESCRIPTION='GPU {{ $labels.gpu }} on {{ $labels.Hostname }} memory usage ratio is {{ $values.B }} (above 0.95).'
# vLLM does not expose GPU memory metrics; use DCGM framebuffer usage instead
ALERT_EXPR="DCGM_FI_DEV_FB_USED / (DCGM_FI_DEV_FB_USED + DCGM_FI_DEV_FB_FREE) > 0.95"
