# Alert: NIMHighTTFT
ALERT_TITLE="NIM High Time-to-First-Token"
ALERT_TEAM="models"
ALERT_FOR="2m"
ALERT_SEVERITY="warning"
ALERT_SUMMARY="High time-to-first-token"
ALERT_DESCRIPTION='P95 time-to-first-token for model {{ $labels.model_name }} is {{ $values.B }}s (above 2s).'
ALERT_EXPR="histogram_quantile(0.95, rate(vllm:time_to_first_token_seconds_bucket[5m])) > 2"
THRESHOLD_OP="gt"
THRESHOLD_VALUE=-1
