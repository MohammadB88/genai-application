# Alert: GPUToolkitNotReady
ALERT_TITLE="GPU Toolkit Not Ready"
ALERT_FOR="10m"
ALERT_SEVERITY="warning"
ALERT_SUMMARY="GPU toolkit pod not ready"
ALERT_DESCRIPTION="The GPU toolkit component is not ready for more than 10 minutes."
ALERT_EXPR="kube_pod_container_status_ready{namespace=\"gpu-operator\", pod=~\".*toolkit.*\"} == 0"
THRESHOLD_OP="gt"
THRESHOLD_VALUE=-1
