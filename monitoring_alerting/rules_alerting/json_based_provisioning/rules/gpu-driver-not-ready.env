# Alert: GPUDriverNotReady
ALERT_TITLE="GPU Driver Not Ready"
ALERT_TEAM="infrastructure"
ALERT_FOR="10m"
ALERT_SEVERITY="critical"
ALERT_SUMMARY="GPU driver pod not ready"
ALERT_DESCRIPTION="The GPU driver component is not ready for more than 10 minutes."
ALERT_EXPR="kmax(ube_pod_container_status_ready{namespace=\"gpu-operator\", pod=~\".*driver.*\"} == bool 0)"
THRESHOLD_OP="gt"
THRESHOLD_VALUE=0