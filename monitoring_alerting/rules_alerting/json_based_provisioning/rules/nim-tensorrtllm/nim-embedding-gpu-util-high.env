# Alert: NIMEmbeddingGPUUtilHigh
ALERT_TITLE="NIM Embedding GPU Util High"
ALERT_TEAM="models"
ALERT_FOR="10m"
ALERT_SEVERITY="warning"
ALERT_SUMMARY="High GPU utilization"
ALERT_DESCRIPTION="GPU utilization > 95% sustained"
# nv_gpu_utilization is a 0.0-1.0 gauge, not a percentage
ALERT_EXPR="nv_gpu_utilization > 0.95"
THRESHOLD_OP="gt"
THRESHOLD_VALUE=-1
