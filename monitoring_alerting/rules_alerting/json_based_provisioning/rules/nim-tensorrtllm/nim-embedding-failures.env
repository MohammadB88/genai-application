# Alert: NIMEmbeddingFailures
ALERT_TITLE="NIM Embedding Failures"
ALERT_TEAM="models"
ALERT_FOR="1m"
ALERT_SEVERITY="critical"
ALERT_SUMMARY="Embedding request failures"
ALERT_DESCRIPTION="Embedding request failure rate > 1%"
ALERT_EXPR="rate(trtllm_request_failures_total[5m]) > 0.01"
THRESHOLD_OP="gt"
THRESHOLD_VALUE=-1
