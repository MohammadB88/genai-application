# Alert: NIMEmbeddingFailures
ALERT_TITLE="NIM Embedding Failures"
ALERT_TEAM="models"
ALERT_FOR="1m"
ALERT_SEVERITY="critical"
ALERT_SUMMARY="Embedding request failures"
ALERT_DESCRIPTION="Failed embedding request rate > 0.01 req/s"
ALERT_EXPR="rate(nv_inference_request_failure[5m]) > 0.01"
THRESHOLD_OP="gt"
THRESHOLD_VALUE=-1
