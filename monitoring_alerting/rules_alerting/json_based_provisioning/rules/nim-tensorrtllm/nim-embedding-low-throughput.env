# Alert: NIMEmbeddingLowThroughput
ALERT_TITLE="NIM Embedding Low Throughput"
ALERT_TEAM="models"
ALERT_FOR="10m"
ALERT_SEVERITY="warning"
ALERT_SUMMARY="Low embedding throughput"
ALERT_DESCRIPTION='Embedding request rate for model {{ $labels.model }} is {{ $values.B }} req/s (below 50).'
ALERT_EXPR="rate(nv_inference_request_success[5m]) < 50"
THRESHOLD_OP="gt"
THRESHOLD_VALUE=-1
