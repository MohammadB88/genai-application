# Alert: NIMEmbeddingLowThroughput
ALERT_TITLE="NIM Embedding Low Throughput"
ALERT_TEAM="models"
ALERT_FOR="10m"
ALERT_SEVERITY="warning"
ALERT_SUMMARY="Low embedding throughput"
ALERT_DESCRIPTION="Embedding requests per second < 50"
ALERT_EXPR="rate(embedding_requests_total[5m]) < 50"
THRESHOLD_OP="gt"
THRESHOLD_VALUE=-1
