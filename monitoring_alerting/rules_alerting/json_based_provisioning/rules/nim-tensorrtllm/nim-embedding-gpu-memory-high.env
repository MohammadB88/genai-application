# Alert: NIMEmbeddingGPUMemoryHigh
ALERT_TITLE="NIM Embedding GPU Memory High"
ALERT_TEAM="models"
ALERT_FOR="5m"
ALERT_SEVERITY="warning"
ALERT_SUMMARY="High GPU memory usage"
ALERT_DESCRIPTION='GPU {{ $labels.gpu_uuid }} memory usage ratio is {{ $values.B }} (above 0.9) during embeddings.'
ALERT_EXPR="nv_gpu_memory_used_bytes / nv_gpu_memory_total_bytes > 0.9"
