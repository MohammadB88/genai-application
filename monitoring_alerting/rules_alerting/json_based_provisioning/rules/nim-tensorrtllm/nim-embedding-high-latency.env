# Alert: NIMEmbeddingHighLatency
ALERT_TITLE="NIM Embedding High Latency"
ALERT_TEAM="models"
ALERT_FOR="2m"
ALERT_SEVERITY="warning"
ALERT_SUMMARY="High embedding latency"
ALERT_DESCRIPTION='Average embedding request latency for model {{ $labels.model }} is {{ $values.B }}us (above 500000us = 500ms).'
# Triton exposes latency as cumulative counters in microseconds (no histograms by default),
# so this alerts on average latency; for p95 enable --metrics-config summary_latencies=true
ALERT_EXPR="rate(nv_inference_request_duration_us[5m]) / rate(nv_inference_request_success[5m]) > 500000"
