# Alert: NIMEmbeddingHighLatency
ALERT_TITLE="NIM Embedding High Latency"
ALERT_TEAM="models"
ALERT_FOR="2m"
ALERT_SEVERITY="warning"
ALERT_SUMMARY="High embedding latency"
ALERT_DESCRIPTION="95th percentile embedding latency > 500ms"
ALERT_EXPR="histogram_quantile(0.95, rate(trtllm_request_latency_ms_bucket[5m])) > 500"
THRESHOLD_OP="gt"
THRESHOLD_VALUE=-1
