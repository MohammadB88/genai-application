# ============================================================
# Global config — shared across all GPU cluster alert rules
# Override any of these in a rule-specific .env file
# ============================================================

GRAFANA_FOLDER_UID="your-folder-uid"
DATASOURCE_UID="your-prometheus-uid"
# ALERT_GROUP="your-alert-group-name" # i.e gpu-cluster-health

# Grafana organisation ID the rules are provisioned into
ORGID=1

# The alert threshold is baked into ALERT_EXPR as a PromQL comparison, which
# already filters out non-breaching series. The expression pipeline is
# A (PromQL) -> B (reduce: last) -> C (threshold), so C only needs to fire
# when any value came back: "greater than -1" acts as "any data present".
# Override these in a rule .env file if you move the threshold out of the expr
# to make it editable in the Grafana GUI.
THRESHOLD_OP="gt"
THRESHOLD_VALUE=-1
